# ============================================
# MOSCATI DIGITAL HEALTH HUB - CONFIGURACIÓN
# ============================================

# PUERTO DE LA APLICACIÓN
PORT=3000
NODE_ENV=development

# ============================================
# GOOGLE GEMINI API (Análisis Clínico con IA)
# ============================================
# Obtener en: https://ai.google.dev/
# 1. Ve a https://ai.google.dev/
# 2. Haz clic en "Get API Key"
# 3. Copia tu clave (comienza con "AIza...")
GOOGLE_GENERATIVE_AI_API_KEY=AIza_YOUR_API_KEY_HERE

# ============================================
# ELEVENLABS API (Síntesis de Voz)
# ============================================
# Obtener en: https://elevenlabs.io/
# 1. Regístrate en https://elevenlabs.io/
# 2. Ve a Settings → API Keys
# 3. Copia tu clave (comienza con "sk_...")
ELEVENLABS_API_KEY=sk_YOUR_API_KEY_HERE

# Selecciona una voz de ElevenLabs
# Voces recomendadas: Antoni, Bella, Rachel, Josh, Sam
# Obtén la lista completa con GET /ai/voices
ELEVENLABS_VOICE_ID=Antoni

# Configuración de síntesis de voz
# Stability: 0.0-1.0 (qué tan consistente es la voz)
# Clarity: 0.0-1.0 (claridad de la pronunciación)
ELEVENLABS_STABILITY=0.5
ELEVENLABS_CLARITY=0.75

# ============================================
# MONGODB (Base de Datos)
# ============================================
# Obtener en: https://www.mongodb.com/cloud/atlas
# Formato: mongodb+srv://usuario:contraseña@cluster.mongodb.net/nombre_db
# Ejemplo: mongodb+srv://admin:password123@cluster0.mongodb.net/moscati-db
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/moscati-db

# Nombre de la base de datos
MONGODB_DATABASE_NAME=moscati-db

# ============================================
# CONFIGURACIÓN DEL HOSPITAL
# ============================================
# Unidades hospitalarias disponibles
# - Moscati Juriquilla
# - Moscati Centro
# - Moscati Satélite
HOSPITAL_DEFAULT_UNIT=Moscati Centro

# ============================================
# CONFIGURACIÓN DE LOGGING
# ============================================
# Nivel de logs: debug, verbose, log, warn, error
LOG_LEVEL=log

# ============================================
# SEGURIDAD
# ============================================
# JWT Secret (cambiar en producción)
JWT_SECRET=tu_secreto_jwt_super_seguro_aqui

# ============================================
# CONFIGURACIÓN DE PROCESAMIENTO
# ============================================
# Timeout máximo para procesamiento de Gemini (ms)
GEMINI_TIMEOUT=30000

# Timeout máximo para síntesis de voz (ms)
ELEVENLABS_TIMEOUT=30000

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA commitear este archivo con valores reales
# 2. Usar un archivo .env.local para desarrollo
# 3. En producción, usar variables de entorno del servidor
# 4. Mantener la estructura del archivo para referencia
